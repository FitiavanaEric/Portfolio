# Copie ce fichier en `.env` (backend) ou configure ces variables sur ton
# hébergeur. backend/db.php et backend/contact.php les lisent avec getenv().

# --- Base de données MySQL ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=portfolio
DB_USER=root
DB_PASSWORD=

# --- Notification par e-mail ---
CONTACT_EMAIL=votre.email@example.com

# --- Frontend (Vite) ---
# URL de base du backend PHP vue par le frontend construit.
# En local avec le proxy Vite, laisse "/backend".
VITE_API_URL=/backend
